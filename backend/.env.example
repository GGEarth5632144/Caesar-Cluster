PORT=8080
DB_URL=postgres://postgres:password@localhost:5433/cloud_cluster?sslmode=disable
JWT_SECRET=dev-secret
FRONTEND_ORIGIN=http://localhost:5173

# mock = ไม่แตะ cluster จริง (ใช้ตอน dev) | kubernetes = deploy ขึ้น k8s จริง
PROVISIONER=mock
# ใช้เมื่อ PROVISIONER=kubernetes เท่านั้น — path ของ kubeconfig
# เว้นว่างไว้ถ้า server รันอยู่ใน cluster เอง (จะใช้ in-cluster config)
KUBECONFIG=

# ---- อีเมลรีเซ็ตรหัสผ่าน (Resend: https://resend.com) ----
# API key จาก Resend dashboard — ว่างไว้ระบบยังรันได้ แต่ส่งอีเมลรีเซ็ตรหัสผ่านไม่ได้
RESEND_API_KEY=
# ผู้ส่งอีเมล — โดเมนต้อง verify ใน Resend ก่อน (ตอน dev ใช้ onboarding@resend.dev ได้เลย)
MAIL_FROM=Caesar Cluster <onboarding@resend.dev>
# อายุของลิงก์รีเซ็ตรหัสผ่าน (นาที)
RESET_TOKEN_TTL_MINUTES=30
